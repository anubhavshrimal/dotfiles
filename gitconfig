[core]
	excludesfile = ~/.gitignore_global
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[commit]
  template = ~/.gitmessage

[color]
  diff = auto
  status = auto
  branch = auto
  interactive = auto
  ui = auto 
  pager = true

# Allow local customizations in the .gitconfig_local file
[include]
	path = ~/.gitconfig_local
